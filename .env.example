# ─────────────────────────────────────────────────────────────
# GEKRAFS Ponorogo — environment variables
# Copy to .env.local for local dev, and set in Vercel Project Settings.
# The site renders fully WITHOUT these (uses built-in seed data); add them
# to switch Berita / Event / Anggota / Daftar to live Supabase data.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
# Server-only — used by the registration server action to insert members.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Prisma (Supabase -> Project Settings -> Database -> Connection string)
# Use the pooled connection (port 6543) for DATABASE_URL and the direct
# connection (port 5432) for DIRECT_URL when running migrations.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
